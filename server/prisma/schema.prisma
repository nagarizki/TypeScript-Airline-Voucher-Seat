// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model crew {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  password String

  flights flight[]
}

model aircraftType {
  id         String @id @default(cuid())
  name       String
  seats      seat[]
  seatType   String
  seatNumber Int

  flightAircraftType flightAircraftType[]
}

model flight {
  id           String   @id @default(cuid())
  flightNumber String
  departure    String
  arrival      String
  date         DateTime
  crewId       String
  crew         crew     @relation(fields: [crewId], references: [id])

  flightVoucherSeatNumbers flightVoucherSeatNumbers[]
  flightAircraftType       flightAircraftType[]
}

model flightVoucherSeatNumbers {
  id       String @id @default(cuid())
  flightId String
  flight   flight @relation(fields: [flightId], references: [id])
  seatId   String
  seat     seat   @relation(fields: [seatId], references: [id])
}

model flightAircraftType {
  id             String @id @default(cuid())
  flightId       String
  flight         flight @relation(fields: [flightId], references: [id])
  aircraftTypeId String
  aircraftType   aircraftType @relation(fields: [aircraftTypeId], references: [id])
}

model seat {
  id             String       @id @default(cuid())
  seatNumber     String
  class          String
  isAvailable    Boolean
  aircraftTypeId String
  aircraftType   aircraftType @relation(fields: [aircraftTypeId], references: [id])

  flightVoucherSeatNumbers flightVoucherSeatNumbers[]
}
