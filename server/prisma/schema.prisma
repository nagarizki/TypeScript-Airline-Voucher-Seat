// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model crew {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  password String

  flightCrew flightCrew[]
}

model aircraftType {
  id         String @id @default(cuid())
  name       String
  seats      seat[]
  seatType   String
  seatNumber Int

  flightAircraftType flightAircraftType[]

  @@map("aircraft_type")
}

model flight {
  id           String   @id @default(cuid())
  flightNumber String
  departure    String
  arrival      String
  date         DateTime

  flightVoucherSeatNumbers flightVoucherSeatNumbers[]
  flightAircraftType       flightAircraftType[]
  flightCrew               flightCrew[]
}

model flightCrew {
  id       String @id @default(cuid())
  flightId String
  flight   flight @relation(fields: [flightId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  crewId   String
  crew     crew   @relation(fields: [crewId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("flight_crew")
}

model flightVoucherSeatNumbers {
  id       String @id @default(cuid())
  flightId String
  flight   flight @relation(fields: [flightId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  seatId   String
  seat     seat   @relation(fields: [seatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("flight_voucher_seat_numbers")
}

model flightAircraftType {
  id             String @id @default(cuid())
  flightId       String
  flight         flight @relation(fields: [flightId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  aircraftTypeId String
  aircraftType   aircraftType @relation(fields: [aircraftTypeId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("flight_aircraft_type")
}

model seat {
  id             String       @id @default(cuid())
  seatNumber     String
  class          String
  isAvailable    Boolean
  aircraftTypeId String
  aircraftType   aircraftType @relation(fields: [aircraftTypeId], references: [id])

  flightVoucherSeatNumbers flightVoucherSeatNumbers[]
}

model voucher {
  id            Int      @id @default(autoincrement())
  crew_name     String   @map("crew_name")
  crew_id       String   @map("crew_id")
  flight_number String   @map("flight_number")
  flight_date   String   @map("flight_date")
  aircraft_type String   @map("aircraft_type")
  seat1         String
  seat2         String
  seat3         String
  created_at    DateTime @default(now()) @map("created_at")

  @@map("vouchers")
}